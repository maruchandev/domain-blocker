{
  "manifest_version": 3,
  "name": "Domain Blocker",
  "version": "1.0.0",
  "description": "Block or allow specific domains. Simple, privacy-first domain management.",
  "permissions": [
    "declarativeNetRequest",
    "storage",
    "activeTab",
    "unlimitedStorage"
  ],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon16.png",
      "48": "icon48.png",
      "128": "icon128.png"
    }
  },
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  },
  "web_accessible_resources": [{
    "resources": ["blocked.html"],
    "matches": ["<all_urls>"]
  }]
}
